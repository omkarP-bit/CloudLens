# Supabase Local Settings (Output from `supabase start`)
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=placeholder_service_role_key
SUPABASE_ANON_KEY=placeholder_anon_key

# AWS KMS Configuration (Set to mock-key to run in sandbox local mode)
KMS_REGION=us-east-1
KMS_CMK_ARN=mock-kms-key

# Redis Settings
REDIS_URL=redis://localhost:6379

# Server Port
PORT=8000

# Gmail SMTP for Budget Alert Emails
# Use a Gmail App Password (not your regular password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM="CloudLens Alerts <your-email@gmail.com>"

# Optional fallback Slack webhook for budget alerts
# Per-budget webhooks can also be set via the UI
SLACK_WEBHOOK_FALLBACK=
